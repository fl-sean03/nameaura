# ----- OpenAI (REQUIRED) -----------------------------------------------------
# Server-side OpenAI API key used by /api/generate (gpt-4o-mini).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ----- Namecheap domains API (RECOMMENDED in production) --------------------
# Used by /api/check-domain for real availability checks. Without these,
# /api/check-domain falls back to a DNS A-record heuristic (wrong on parked
# domains) and logs a one-time warning.
# 1. Enable API access at https://ap.www.namecheap.com/settings/tools/apiaccess/
# 2. Whitelist the IP your server calls from (see README — Vercel serverless
#    rotates egress IPs; use a static-IP proxy like QuotaGuard Static or
#    deploy on a runtime with stable egress).
# 3. Set NAMECHEAP_CLIENT_IP to the whitelisted IP.
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=

# ----- Cloudflare Turnstile (RECOMMENDED in production) ---------------------
# Invisible captcha that blocks bots without user friction.
# 1. Cloudflare dashboard → Turnstile → "Add site"
# 2. Choose widget mode "Invisible", domain nameaura.co (+ www)
# 3. Copy the Site Key → NEXT_PUBLIC_TURNSTILE_SITE_KEY (browser-safe)
# 4. Copy the Secret Key → TURNSTILE_SECRET_KEY (server-only)
# If both are unset, captcha verification is skipped (dev mode) with a warning.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ----- Upstash Redis (RECOMMENDED in production) -----------------------------
# Backs serverless-friendly rate limiting AND the global daily budget counter.
# 1. https://console.upstash.com → "Create Database" → Redis, free tier
# 2. Pick region near your Vercel deploy (iad1 for US, fra1 for EU)
# 3. Copy the "REST URL" and "REST Token" from the database details page
# If unset, we fall back to in-memory limits (NOT durable across serverless
# invocations — dev use only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----- Optional tunables -----------------------------------------------------
# Max successful /api/generate calls per UTC day. Default: 200.
DAILY_GENERATION_LIMIT=200

# Salt added before hashing IPs in abuse logs. Any random string works.
IP_HASH_SALT=change-me-in-prod
